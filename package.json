{
	"name": "nacc-home",
	"version": "0.1.0",
	"description": "National Aquatic Connectivity Collaborative",
	"author": "Brendan C. Ward <bcward@astutespruce.com>",
	"license": "MIT",
	"private": false,
	"type": "module",
	"scripts": {
		"dev": "vite dev",
		"build": "vite build",
		"preview": "vite preview",
		"prepare": "svelte-kit sync || echo ''",
		"check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
		"check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
		"lint": "eslint .",
		"predeploy": "npm run build",
		"deploy": "rm -rf /var/www/nacc-home/* && cp -r public/* /var/www/nacc-home"
	},
	"dependencies": {
		"@internationalized/date": "^3.12.1",
		"@sentry/svelte": "^10.53.1",
		"@sveltejs/adapter-static": "^3.0.10",
		"@sveltejs/enhanced-img": "^0.10.4",
		"@sveltejs/kit": "^2.61.1",
		"@sveltejs/vite-plugin-svelte": "^7.1.2",
		"@tailwindcss/vite": "^4.3.0",
		"@types/node": "^25",
		"bits-ui": "^2.18.1",
		"clsx": "^2.1.1",
		"dotenv": "^17.4.2",
		"globals": "^17.6.0",
		"svelte": "^5.55.9",
		"svelte-check": "^4.4.8",
		"tailwind-merge": "^3.6.0",
		"tailwind-variants": "^3.2.2",
		"tailwindcss": "^4.3.0",
		"tw-animate-css": "^1.4.0",
		"typescript": "^6.0.3",
		"vite": "^8.0.14"
	},
	"devDependencies": {
		"@eslint/compat": "^2.1.0",
		"@eslint/js": "^10.0.1",
		"@lucide/svelte": "^1.16.0",
		"eslint": "^10.4.0",
		"eslint-config-prettier": "^10.1.8",
		"eslint-plugin-svelte": "^3.17.1",
		"prettier": "^3.8.3",
		"prettier-plugin-tailwindcss": "^0.8.0",
		"typescript-eslint": "^8.59.4"
	},
	"repository": {
		"type": "git",
		"url": "https://github.com/astutespruce/nacc-home"
	},
	"bugs": {
		"url": "https://github.com/astutespruce/nacc-home/issues"
	}
}
